---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description?: string;
  domain?: string;
  breadcrumbs?: { label: string; href?: string }[];
  section?: string;
  fileCounts?: Record<string, number>;
}

const { title, description, domain, breadcrumbs = [], section, fileCounts = {} } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  domain={domain}
  section={section}
  fileCounts={fileCounts}
>
  {breadcrumbs.length > 0 && <Breadcrumb items={breadcrumbs} />}
  <article class="doc-content">
    <h1>{title}</h1>
    <slot />
  </article>
</BaseLayout>

<style>
  .doc-content {
    max-width: 72ch;
  }

  .doc-content h1 {
    margin-bottom: var(--md-sys-spacing-6, 1.5rem);
    padding-bottom: var(--md-sys-spacing-2, 0.5rem);
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .doc-content h2 {
    margin-top: var(--md-sys-spacing-8, 2rem);
    margin-bottom: var(--md-sys-spacing-2, 0.5rem);
  }

  .doc-content p {
    margin-bottom: var(--md-sys-spacing-4, 1rem);
  }

  .doc-content ul, .doc-content ol {
    margin-bottom: var(--md-sys-spacing-4, 1rem);
    padding-left: var(--md-sys-spacing-6, 1.5rem);
  }

  .doc-content blockquote {
    border-left: 3px solid var(--md-sys-color-primary);
    padding-left: var(--md-sys-spacing-4, 1rem);
    margin: var(--md-sys-spacing-4, 1rem) 0;
    color: var(--md-sys-color-on-surface-variant);
  }
</style>