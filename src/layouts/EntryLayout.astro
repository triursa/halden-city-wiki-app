---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description?: string;
  section: string;
  breadcrumbs?: { label: string; href?: string }[];
  fileCounts?: Record<string, number>;
  backlinks?: string[];
  backlinkLabels?: Record<string, string>;
  outboundLinks?: { target: string; label: string }[];
}

const {
  title,
  description,
  section,
  breadcrumbs = [],
  fileCounts = {},
  backlinks = [],
  backlinkLabels = {},
  outboundLinks = [],
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  domain="masks"
  section={section}
  fileCounts={fileCounts}
>
  {breadcrumbs.length > 0 && <Breadcrumb items={breadcrumbs} />}

  <article class="entry-content" data-section={section}>
    <h1>{title}</h1>

    <!-- Portrait slot -->
    <div class="portrait-slot">
      <slot name="portraits" />
    </div>

    <!-- Scene image slot -->
    <div class="scene-slot">
      <slot name="scene" />
    </div>

    <!-- Main content -->
    <div class="entry-body">
      <slot />
    </div>

    <!-- Relationships slot -->
    <div class="relationships-slot">
      <slot name="relationships" />
    </div>

    <!-- Backlinks -->
    {backlinks.length > 0 && (
      <div class="backlinks-section">
        <h3>Referenced by</h3>
        <ul class="backlinks-list">
          {backlinks.map((id) => (
            <li>
              <a href={`/entry/${id}`} class="backlink-chip">
                {backlinkLabels[id] || id}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Outbound links -->
    {outboundLinks.length > 0 && (
      <div class="outbound-section">
        <h3>Connections</h3>
        <ul class="backlinks-list">
          {outboundLinks.map(({ target, label }) => (
            <li>
              <a href={`/entry/${target}`} class="backlink-chip">
                {label || target}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .entry-content {
    max-width: 72ch;
  }

  .entry-content h1 {
    margin-bottom: var(--md-sys-spacing-6, 1.5rem);
    padding-bottom: var(--md-sys-spacing-2, 0.5rem);
    border-bottom: 2px solid var(--section-color);
  }

  .entry-content h2 {
    margin-top: var(--md-sys-spacing-8, 2rem);
    margin-bottom: var(--md-sys-spacing-2, 0.5rem);
  }

  .entry-content p {
    margin-bottom: var(--md-sys-spacing-4, 1rem);
  }

  .entry-content ul, .entry-content ol {
    margin-bottom: var(--md-sys-spacing-4, 1rem);
    padding-left: var(--md-sys-spacing-6, 1.5rem);
  }

  .entry-content blockquote {
    border-left: 3px solid var(--section-color, var(--md-sys-color-primary));
    padding-left: var(--md-sys-spacing-4, 1rem);
    margin: var(--md-sys-spacing-4, 1rem) 0;
    color: var(--md-sys-color-on-surface-variant);
  }

  .portrait-slot {
    margin: 1rem 0;
  }

  .scene-slot {
    margin: 1rem 0;
  }
</style>