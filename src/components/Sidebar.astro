---
import { SECTIONS, type Section } from '../config/sections';

interface Props {
  currentPath: string;
  fileCounts?: Record<string, number>;
}

const { currentPath, fileCounts = {} } = Astro.props;

// Determine current section from path
const currentSection = currentPath.split('/')[1] || '';
---

<aside class="sidebar" aria-label="Sidebar navigation">
  <div class="sidebar-header">
    <a href="/" class="sidebar-brand">🎭 Halden City</a>
  </div>
  <nav class="sidebar-nav">
    <ul>
      {SECTIONS.map((section: Section) => {
        const isActive = currentSection === section.key;
        const count = fileCounts[section.key] ?? 0;
        return (
          <li>
            <a
              href={`/${section.key}`}
              class:list={['sidebar-link', { active: isActive }]}
              style={isActive ? { borderLeftColor: section.color } : {}}
              aria-current={isActive ? 'page' : undefined}
            >
              <span class="sidebar-icon">{section.icon}</span>
              <span class="sidebar-label">{section.label}</span>
              {count > 0 && <span class="sidebar-count">{count}</span>}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 0;
    width: 260px;
    height: 100vh;
    background: var(--md-sys-color-surface-container-low);
    border-right: 1px solid var(--md-sys-color-outline-variant);
    overflow-y: auto;
    padding: var(--md-sys-spacing-4, 1rem) 0;
    flex-shrink: 0;
  }

  .sidebar-header {
    padding: 0 var(--md-sys-spacing-4, 1rem) var(--md-sys-spacing-4, 1rem);
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
    margin-bottom: var(--md-sys-spacing-2, 0.5rem);
  }

  .sidebar-brand {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    text-decoration: none;
  }

  .sidebar-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: var(--md-sys-spacing-2, 0.5rem);
    padding: var(--md-sys-spacing-2, 0.5rem) var(--md-sys-spacing-4, 1rem);
    color: var(--md-sys-color-on-surface-variant);
    text-decoration: none;
    font-size: 0.875rem;
    transition: background-color var(--transition), color var(--transition);
    border-left: 3px solid transparent;
  }

  .sidebar-link:hover {
    background: var(--md-sys-color-surface-container);
    color: var(--md-sys-color-on-surface);
  }

  .sidebar-link.active {
    font-weight: 500;
  }

  .sidebar-icon {
    font-size: 1rem;
    width: 1.25rem;
    text-align: center;
    flex-shrink: 0;
  }

  .sidebar-label {
    flex: 1;
  }

  .sidebar-count {
    font-size: 0.75rem;
    color: var(--md-sys-color-on-surface-variant);
    background: var(--md-sys-color-surface-container);
    padding: 0.125rem 0.5rem;
    border-radius: var(--md-sys-shape-corner-small);
  }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: -260px;
      z-index: 100;
      transition: left 0.3s ease;
    }
    .sidebar.open {
      left: 0;
    }
  }
</style>