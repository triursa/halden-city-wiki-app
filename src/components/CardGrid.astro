---
interface CardItem {
  title: string;
  description?: string;
  href: string;
  tags?: string[];
  thumbnail?: string;
}

interface Props {
  items: CardItem[];
  accentColor?: string;
}

const { items, accentColor } = Astro.props;
---

<div class="card-grid" style={accentColor ? { '--section-color': accentColor } : {}}>
  {items.map((item) => (
    <a href={item.href} class="entry-card">
      <div class="card-row">
        {item.thumbnail && (
          <img src={item.thumbnail} alt="" class="card-thumb" loading="lazy" />
        )}
        <div class="card-body">
          <h3 class="card-title">{item.title}</h3>
          {item.description && <p class="card-desc">{item.description}</p>}
          {item.tags && item.tags.length > 0 && (
            <div class="card-tags">
              {item.tags.slice(0, 3).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </a>
  ))}
</div>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--md-sys-spacing-4, 1rem);
  }

  .entry-card {
    background: var(--md-sys-color-surface-container-low);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-left: 4px solid var(--section-color);
    border-radius: var(--md-sys-shape-corner-medium);
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .entry-card:hover {
    box-shadow: var(--md-sys-elevation-2);
    border-color: var(--md-sys-color-outline);
  }

  .card-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .card-thumb {
    width: 48px;
    height: 48px;
    border-radius: var(--md-sys-shape-corner-small);
    object-fit: cover;
    flex-shrink: 0;
  }

  .card-body {
    flex: 1;
    min-width: 0;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--section-color);
    margin-bottom: 0.25rem;
  }

  .card-desc {
    font-size: 0.8125rem;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.5;
    margin-bottom: 0.375rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .card-tags {
    display: flex;
    gap: var(--md-sys-spacing-1, 0.25rem);
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
    border-radius: var(--md-sys-shape-corner-small);
  }
</style>